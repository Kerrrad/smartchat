APP_NAME=SmartChat Automation
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=zmien-mnie-na-losowy-sekret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DATABASE_URL=postgresql+asyncpg://smartchat:smartchat@db:5432/smartchat
REDIS_URL=redis://redis:6379/0
ENABLE_CELERY_DISPATCH=true
ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
LOG_LEVEL=INFO
APP_TIMEZONE=Europe/Warsaw
DEFAULT_ADMIN_EMAIL=admin@smartchat.local
DEFAULT_ADMIN_PASSWORD=Admin123!
